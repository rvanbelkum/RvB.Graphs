<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>

		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
		<Title>Various graph based data structures and algorithms</Title>
		<Authors>rvanbelkum</Authors>
		<Description>Various graph based data structures and algorithms</Description>
		<PackageProjectUrl>https://github.com/rvanbelkum/RvB.Graphs</PackageProjectUrl>
		<RepositoryUrl>https://github.com/rvanbelkum/RvB.Graphs</RepositoryUrl>
		<NeutralLanguage>en</NeutralLanguage>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://licenses.nuget.org/MIT</PackageProjectUrl>
		<PackageReadmeFile>readme.md</PackageReadmeFile>
		<PackageVersion>1.0.0</PackageVersion>
		<AssemblyVersion>1.0.0.0</AssemblyVersion>
		<FileVersion>1.0.0.0</FileVersion>
	</PropertyGroup>

	<ItemGroup>
		<None Remove=".gitattributes" />
		<None Remove=".gitignore" />
		<None Include="readme.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="RvB.Collections" Version="1.0.2" />
	</ItemGroup>

</Project>
